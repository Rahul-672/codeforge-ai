server:
  port: 8080

spring:
  application:
    name: api-gateway

jwt:
  secret: YOUR_JWT_SECRET_256_BIT_KEY

services:
  auth-url: http://localhost:8081
  project-url: http://localhost:8082
  ingestion-url: http://localhost:8083

management:
  endpoints:
    web:
      exposure:
        include: health,info
  endpoint:
    health:
      show-details: always