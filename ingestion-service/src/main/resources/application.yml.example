server:
  port: 8083

spring:
  application:
    name: ingestion-service
  datasource:
    url: jdbc:postgresql://localhost:5433/codeforge
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false

minio:
  url: http://localhost:9000
  access-key: YOUR_MINIO_ACCESS_KEY
  secret-key: YOUR_MINIO_SECRET_KEY
  bucket: codeforge-repos

github:
  token: ${GITHUB_TOKEN:}

ollama:
  url: http://localhost:11434

qdrant:
  host: localhost
  port: 6334

management:
  endpoints:
    web:
      exposure:
        include: health,info
  endpoint:
    health:
      show-details: always